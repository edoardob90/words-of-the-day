---
import { Box, Zap, Palette, Gauge, ArrowRightLeft } from "@lucide/astro";
import { posStyles } from "../config";

interface Props {
  pos: string;
}

const { pos } = Astro.props;

const icons: Record<string, typeof Box> = {
  Noun: Box,
  Verb: Zap,
  Adjective: Palette,
  Adverb: Gauge,
  Preposition: ArrowRightLeft,
};

const Icon = icons[pos];
const colors = posStyles[pos as keyof typeof posStyles];
---

<span
  class:list={[
    "inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full",
    colors?.base,
  ]}
>
  {Icon && <Icon size={12} />}
  {pos}
</span>
