---
import { posStyles } from "../config";

interface Props {
  href: string;
  active?: boolean;
  variant?:
    | "default"
    | "incomplete"
    | "starred"
    | "noun"
    | "verb"
    | "adjective"
    | "adverb"
    | "preposition";
}

const { href, active = false, variant = "default" } = Astro.props;

const staticVariants: Record<
  string,
  { base: string; hover: string; active: string }
> = {
  default: {
    base: "bg-stone-100 text-stone-600",
    hover: "hover:bg-stone-200",
    active: "bg-stone-900 text-white",
  },
  incomplete: {
    base: "bg-red-100 text-red-600",
    hover: "hover:bg-red-200",
    active: "bg-red-700 text-white",
  },
  starred: {
    base: "bg-amber-100 text-amber-600",
    hover: "hover:bg-amber-200",
    active: "bg-amber-600 text-white",
  },
};

const posKey = variant.charAt(0).toUpperCase() + variant.slice(1);
const colors =
  staticVariants[variant] ?? posStyles[posKey as keyof typeof posStyles];
---

<a
  href={href}
  class:list={[
    "text-xs px-3 py-1 rounded-full transition-colors",
    active ? colors?.active : [colors?.base, colors?.hover],
  ]}
>
  <slot />
</a>
