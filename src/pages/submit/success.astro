---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Word Submitted">
    <div class="text-center py-16">
        <h1 class="text-2xl font-bold mb-4">Thanks!</h1>
        <p class="text-stone-600 mb-6">
            Your word has been submitted for review.
        </p>
        <a
            href="/"
            class="inline-block bg-stone-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-stone-700 transition-colors"
        >
            Back to words
        </a>
    </div>
</BaseLayout>
