---
export const prerender = false;

import { getWords, enrichLanguages, getPosCounts } from "../lib/words";
import { partsOfSpeech } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
import WordCard from "../components/WordCard.astro";
import FilterChip from "../components/FilterChip.astro";

const q = Astro.url.searchParams.get("q") ?? undefined;
const pos = Astro.url.searchParams.get("pos") ?? undefined;
const filter = Astro.url.searchParams.get("filter") ?? undefined;

// Fetch words based on the search query param
const allWords = await getWords({ q });
const posCounts = getPosCounts(allWords);

const incompleteCount = allWords.filter((w) => !w.isComplete).length;
const starredCount = allWords.filter((w) => w.favourite).length;

// Apply filter and POS in memory
let words = allWords;
if (filter === "incomplete") words = words.filter((w) => !w.isComplete);
if (filter === "starred") words = words.filter((w) => w.favourite);
if (pos)
  words = words.filter((w) => (w.partOfSpeech as string[]).includes(pos));

function chipHref(opts?: { pos?: string; filter?: string }) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (opts?.pos) params.set("pos", opts.pos);
  if (opts?.filter) params.set("filter", opts.filter);
  const qs = params.toString();
  return qs ? `/?${qs}` : "/";
}
---

<BaseLayout>
  <div class="flex flex-col gap-4 mb-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">
        {q ? `Results for "${q}"` : "All Words"}
      </h1>
      {
        (q || pos || filter) && (
          <a href="/" class="text-sm text-stone-500 hover:text-stone-700">
            Clear filters
          </a>
        )
      }
    </div>

    <div class="flex flex-wrap items-center justify-between gap-2">
      <div class="flex flex-wrap gap-2">
        <FilterChip href={chipHref()} active={!filter && !pos}>
          All ({allWords.length})
        </FilterChip>
        {
          incompleteCount !== 0 && (
            <FilterChip href={chipHref({ filter: "incomplete" })} variant="incomplete" active={filter === "incomplete"}>
              Incomplete ({incompleteCount})
            </FilterChip>
          )
        }
        {
          starredCount !== 0 && (
            <FilterChip href={chipHref({ filter: "starred" })} variant="starred" active={filter === "starred"}>
              Starred ({starredCount})
            </FilterChip>
          )
        }
      </div>
      <div class="flex flex-wrap gap-2">
        {
          partsOfSpeech.map((p) =>
            posCounts[p] ? (
              <FilterChip href={chipHref({ pos: p })} variant={p.toLowerCase() as any} active={pos === p}>
                {p} ({posCounts[p] ?? 0})
              </FilterChip>
            ) : null,
          )
        }
      </div>
    </div>
  </div>

  {
    words.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {words.map((w) => (
          <WordCard
            word={w.word}
            slug={w.slug}
            meaning={w.meaning ?? undefined}
            partOfSpeech={w.partOfSpeech as string[]}
            languages={enrichLanguages(w.languages as Record<string, string>)}
            favourite={w.favourite}
            isComplete={w.isComplete}
            featured={w.featured}
          />
        ))}
      </div>
    ) : (
      <p class="text-stone-400 text-sm">No words found.</p>
    )
  }
</BaseLayout>
