---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WordDetail from "../components/WordDetail.astro";

export async function getStaticPaths() {
    const words = await getCollection("words");
    return words.map((entry) => ({
        params: { word: entry.data.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<BaseLayout title={`${data.word} — Word of the Day`}>
    <a
        href="/"
        class="text-sm text-stone-500 hover:text-stone-700 mb-6 inline-block"
    >
        &larr; Back to all words
    </a>
    <WordDetail
        word={data.word}
        meaning={data.meaning}
        partOfSpeech={data.partOfSpeech}
        languages={data.languages}
        favourite={data.favourite}
        created={data.created}
        featured={data.featured}
        relatedWords={data.relatedWords}
        origin={data.origin}
    >
        <Content />
    </WordDetail>
</BaseLayout>
